# 아리아 RAG POC 환경설정 (.env 로 복사해서 사용)
# 기본값은 제공된 구동 환경 정보와 동일하므로, 그대로면 수정 불필요.

# --- 검색 모델 (harness-1) ---
HARNESS1_BASE_URL=http://192.168.1.108:8000/v1
HARNESS1_MODEL=harness-1
HARNESS1_API_KEY=EMPTY
HARNESS1_TEMPERATURE=0.7
HARNESS1_MAX_TOKENS=4096
HARNESS1_MAX_TURNS=8

# --- 임베딩 모델 ---
# backend: local_bge_m3(로컬 BAAI/bge-m3) | openai(원격 OpenAI 호환 엔드포인트)
EMBED_BACKEND=local_bge_m3
EMBED_LOCAL_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu
EMBED_NORMALIZE=1
EMBED_DIM=1024
# (openai 백엔드 사용 시에만 필요)
EMBED_BASE_URL=http://192.168.1.108:8081/v1
EMBED_MODEL=qwen3-embedding
EMBED_API_KEY=EMPTY

# --- 리랭커 (Qwen3-Reranker-8B, vLLM /score) ---
RERANK_URL=http://192.168.1.108:8003/score
RERANK_MODEL=Qwen/Qwen3-Reranker-8B
RERANK_ENABLED=1

# --- 오케스트레이터 (exaone3.5:32b, Ollama) ---
ORCH_BASE_URL=http://192.168.1.108:11434/v1
ORCH_MODEL=exaone3.5:32b
ORCH_API_KEY=ollama
ORCH_TEMPERATURE=0.3
# 검색 전 질의를 영어로 번역 (0=원문 그대로 검색, 1=영어 번역 후 검색)
TRANSLATE_QUERY_TO_ENGLISH=0

# --- 웹검색 : 혼합식 도구 ---
# WEB_SEARCH_ENABLED=1 이고 해당 provider 키가 있으면 harness-1에 web_search 도구가 노출됨
WEB_SEARCH_ENABLED=1
# provider: serpapi(serpapi.com) | serper(serper.dev)
WEB_SEARCH_PROVIDER=serpapi
SERPAPI_API_KEY=
SERPER_API_KEY=
JINA_API_KEY=
WEB_SEARCH_LIMIT=10
WEB_READ_MAX_CHARS=6000

# --- 벡터스토어 (Qdrant) ---
QDRANT_URL=http://192.168.1.10:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_bsss
# payload 필드명 (kb_bsss: content/doc_id/chunk_id)
QDRANT_TEXT_FIELD=content
QDRANT_DOCID_FIELD=doc_id
QDRANT_CHUNKID_FIELD=chunk_id
# named vector 이름
QDRANT_VECTOR_NAME=dense

# --- 검색 파이프라인 파라미터 ---
SEARCH_LIMIT=50
RERANK_TOP_K=10
SYNTH_TOP_K=6
REQUEST_TIMEOUT=120

# =====================================================================
# 버전별 라우터 (v1/v2) 의 "임베딩 + 벡터스토어" 는 아래 값으로 고정된다.
# 위쪽 QDRANT_*/EMBED_* 는 v1/v2 어디에도 직접 쓰이지 않으며(공유 설정만 사용),
# 버전별 백엔드는 아래 V1_*/V2_* 로 제어한다. 주석 처리된 값은 코드 기본값과 동일.
# harness-1·리랭커·오케스트레이터·웹검색은 v1·v2 가 공유한다(위 설정 사용).
# =====================================================================

# --- v1 라우터 (임베딩 qwen3-embedding + 벡터스토어 browsecompplus_qwen3_1024) ---
# V1_EMBED_BACKEND=openai
# V1_EMBED_BASE_URL=http://192.168.1.108:8081/v1
# V1_EMBED_MODEL=qwen3-embedding
# V1_EMBED_API_KEY=EMPTY
# V1_EMBED_DIM=1024
# V1_QDRANT_URL=http://192.168.1.10:6333
# V1_QDRANT_API_KEY=
# V1_QDRANT_COLLECTION=browsecompplus_qwen3_1024
# V1_QDRANT_VECTOR_NAME=dense
# V1_QDRANT_TEXT_FIELD=document
# V1_QDRANT_DOCID_FIELD=source
# V1_QDRANT_CHUNKID_FIELD=chunk_id
# 하이브리드(dense+sparse): sparse=bm25(modifier=IDF). 끄려면 V1_SPARSE_ENABLED=0
# V1_SPARSE_ENABLED=1
# V1_SPARSE_VECTOR_NAME=bm25
# V1_SPARSE_METHOD=bm25
# V1_SPARSE_MODEL=Qdrant/bm25

# --- v2 라우터 (임베딩 BAAI/bge-m3 + 벡터스토어 kb_bsss) ---
# /v2/* 엔드포인트 전용 오버라이드. 아래 값은 코드 기본값과 동일하므로 그대로면 설정 불필요.
# V2_EMBED_BACKEND=local_bge_m3
# V2_EMBED_LOCAL_MODEL=BAAI/bge-m3
# V2_EMBED_DIM=1024
# V2_EMBED_DEVICE=cpu
# V2_QDRANT_URL=http://121.78.130.83:6333
# V2_QDRANT_API_KEY=
# V2_QDRANT_COLLECTION=kb_bsss
# V2_QDRANT_VECTOR_NAME=dense
# V2_QDRANT_TEXT_FIELD=content
# V2_QDRANT_DOCID_FIELD=doc_id
# V2_QDRANT_CHUNKID_FIELD=chunk_id
# 하이브리드(dense+sparse): sparse=bge-m3 lexical weights. 끄려면 V2_SPARSE_ENABLED=0
# V2_SPARSE_ENABLED=1
# V2_SPARSE_VECTOR_NAME=sparse
# V2_SPARSE_METHOD=bge_m3
# V2_SPARSE_MODEL=BAAI/bge-m3

# 하이브리드 공통: 융합 전 각 분기(dense/sparse) 후보 수
# HYBRID_PREFETCH_LIMIT=50
